{
  "name": "dresden-titans-hub",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate:dev": "turbo run db:migrate:dev",
    "db:studio": "pnpm --filter @dresden-titans/database db:studio",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "docker:dev": "docker compose --profile development up --build",
    "docker:dev:down": "docker compose --profile development down",
    "docker:prod": "docker compose --profile production up --build -d",
    "docker:prod:down": "docker compose --profile production down",
    "docker:full": "docker compose --profile full up --build -d",
    "docker:full:down": "docker compose --profile full down",
    "docker:clean": "docker compose down -v --rmi all --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:rebuild": "docker compose build --no-cache"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.10.4",
    "typescript": "^5.7.0"
  }
}