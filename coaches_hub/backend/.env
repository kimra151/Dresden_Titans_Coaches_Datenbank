NODE_ENV="development"
PORT=3000

# Deine Supabase PostgreSQL Verbindungs-URL (findest du im Supabase Dashboard unter Settings -> Database)
DATABASE_URL="postgresql://postgres.[DEINE-PROJEKT-REF]:[DEIN-PASSWORT]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Deine Cloudflare R2 Credentials (findest du im Cloudflare Dashboard unter R2 -> Manage API Tokens)
S3_ENDPOINT="https://[DEINE-ACCOUNT-ID].r2.cloudflarestorage.com"
S3_ACCESS_KEY="dein_cloudflare_access_key"
S3_SECRET_KEY="dein_cloudflare_secret_key"
S3_BUCKET_NAME="drill-videos"